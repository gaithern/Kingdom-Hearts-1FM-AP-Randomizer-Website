{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Serve site locally",
            "type": "shell",
            "command": "python",
            "args": ["-m", "http.server", "8000"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Serving HTTP"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
